# ==============================================================================
# IONOS RHUI Status Dashboard - example environment configuration
#
# ARCHITECTURE NOTE: this app has no direct access to IONOS's RHUI (Red Hat
# Update Infrastructure) servers. Instead, you point it at one or more RHUI
# *test clients* -- ordinary VMs already registered to pull updates from
# IONOS RHUI (any RHEL release; the app detects it automatically). The app
# SSHes into each test client and runs the same checks a real "dnf update"
# would run: reading the client's own repo config, resolving and reaching the
# RHUI server, validating certificates, and attempting a live metadata fetch
# and update check. This reproduces exactly what a customer's server
# experiences.
#
# Test clients can be found automatically via the IONOS Cloud API (see
# IONOS_API_TOKEN below) or entered manually in the setup form.
#
# Copy this file to ".env" and fill in the values for your environment.
# If no ".env" is present, the app will present a setup form in the browser
# to collect this same information at runtime, kept in server memory only for
# that process's lifetime -- the app never writes configuration to disk, so
# it must be re-supplied (a fresh ".env", the form, or "Upload .env") every
# time the app restarts or is opened in a new session.
# ==============================================================================

# --- Web server -------------------------------------------------------------
# The app itself listens on this internal port; nginx on web1 reverse-proxies
# the IONOS ALB's external port 8085 (85.215.173.84:8085) to 127.0.0.1:3006.
# See deploy/nginx-rhui-status.conf. Change only if that mapping is updated too.
PORT=3006
SESSION_SECRET=change-me-to-a-random-string

# --- IONOS Cloud API (optional) ----------------------------------------------
# Used by the "Discover RHEL hosts" button in the setup form to search your
# VM inventory for RHEL servers (detected via each volume's licenceType).
# A token with read access to datacenters/servers/images is enough.
IONOS_API_TOKEN=
# Only needed for reseller/admin tokens acting on behalf of another contract;
# sent as the X-Contract-Number header.
IONOS_CONTRACT_NUMBER=

# --- RHUI test clients ---------------------------------------------------------
# One or more hosts to monitor, as a JSON array. Each entry:
#   { "label": "...", "host": "10.0.0.10", "port": 22, "username": "cloud-user",
#     "keyPath": "/home/app/.ssh/client_key", "keyContent": "", "passphrase": "" }
# Use either keyPath (recommended) or keyContent (paste the full PEM, with
# real or "\n"-escaped line breaks -- both are handled). Usually easiest to
# populate this via the setup form (discovery or manual entry) and "Save to
# .env", rather than hand-editing JSON here.
RHUI_HOSTS_JSON=[]

# --- RHUI detection -------------------------------------------------------------
# Case-insensitive substring match against each repo's id/baseurl found in the
# client's /etc/yum.repos.d/*.repo files, used to pick out the RHUI repos from
# everything else configured on the box.
RHUI_REPO_FILTER=rhui

# Optional: compare a discovered RHUI repo's live metadata against the public
# Red Hat CDN to see how far behind the public mirrors it is. There's no
# reliable way to derive the public URL from a private RHUI baseurl, so this
# is an explicit opt-in mapping: repoId|publicRepomdUrl, separated by ";".
RHUI_MONITORED_REPOS=rhel-9-for-x86_64-baseos-rhui-rpms|https://cdn.redhat.com/content/dist/rhel9/9/x86_64/baseos/os/repodata/repomd.xml

# --- Timeouts (ms) -------------------------------------------------------------
SSH_TIMEOUT_MS=8000
CDN_TIMEOUT_MS=8000

# --- Auto refresh --------------------------------------------------------------
# How often the dashboard polls for fresh status data, in seconds.
STATUS_POLL_INTERVAL_SECONDS=60
