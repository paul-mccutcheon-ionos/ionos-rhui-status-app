# ==============================================================================
# IONOS RHUI Status Dashboard - example environment configuration
#
# Copy this file to ".env" and fill in the values for your environment.
# If no ".env" is present, the app will present a setup form in the browser
# to collect this same information at runtime (kept in memory unless you
# explicitly choose to save it).
# ==============================================================================

# --- Web server -------------------------------------------------------------
# The app itself listens on this internal port; nginx on web1 reverse-proxies
# the IONOS ALB's external port 8085 (85.215.173.84:8085) to 127.0.0.1:3006.
# See deploy/nginx-rhui-status.conf. Change only if that mapping is updated too.
PORT=3006
SESSION_SECRET=change-me-to-a-random-string

# --- RHEL 8 RHUI host ---------------------------------------------------------
RHEL8_LABEL=RHUI RHEL 8
RHEL8_HOST=
RHEL8_SSH_PORT=22
RHEL8_SSH_USER=cloud-user
# Path to a private key file readable by this app (recommended over pasting content)
RHEL8_SSH_KEY_PATH=
# Alternative to RHEL8_SSH_KEY_PATH: paste the full PEM key content here.
# Preserve line breaks as literal "\n" if setting this in a single-line .env value.
RHEL8_SSH_KEY_CONTENT=
RHEL8_SSH_PASSPHRASE=

# --- RHEL 9 RHUI host ---------------------------------------------------------
RHEL9_LABEL=RHUI RHEL 9
RHEL9_HOST=
RHEL9_SSH_PORT=22
RHEL9_SSH_USER=cloud-user
RHEL9_SSH_KEY_PATH=
RHEL9_SSH_KEY_CONTENT=
RHEL9_SSH_PASSPHRASE=

# --- RHUI checks --------------------------------------------------------------
# Comma-separated systemd services to check on each host.
RHUI_SERVICES=httpd,pulpcore-api,pulpcore-content,pulpcore-worker@1,pulpcore-worker@2,nginx,squid

# Path on the host used for data/disk-availability checks.
RHUI_DATA_PATH=/var/lib/pulp

# Path on the host to the Red Hat entitlement certificate used for expiry checks.
RHUI_ENTITLEMENT_CERT_PATH=/etc/pki/entitlement/entitlement.pem

# TLS port the app connects to directly (no SSH) to check the certificate that
# RHEL clients actually see when yum/dnf hits the RHUI content server. This is
# the cert that commonly expires and silently breaks client updates.
RHUI_CLIENT_TLS_PORT=443

# Repos to compare for update freshness against the public Red Hat CDN.
# Format: repoId|local_repomd_path|public_repomd_url ; separate multiple entries with a semicolon.
RHUI_MONITORED_REPOS=rhel-8-for-x86_64-baseos-rpms|/var/lib/rhui/remote_share/symlinks/rhel-8-for-x86_64-baseos-rpms/repodata/repomd.xml|https://cdn.redhat.com/content/dist/rhel8/8/x86_64/baseos/os/repodata/repomd.xml;rhel-9-for-x86_64-baseos-rpms|/var/lib/rhui/remote_share/symlinks/rhel-9-for-x86_64-baseos-rpms/repodata/repomd.xml|https://cdn.redhat.com/content/dist/rhel9/9/x86_64/baseos/os/repodata/repomd.xml

# --- Timeouts (ms) -------------------------------------------------------------
SSH_TIMEOUT_MS=8000
CDN_TIMEOUT_MS=8000

# --- Auto refresh --------------------------------------------------------------
# How often the dashboard polls for fresh status data, in seconds.
STATUS_POLL_INTERVAL_SECONDS=60
