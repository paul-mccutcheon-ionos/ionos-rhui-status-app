# ==============================================================================
# IONOS RHUI Status Dashboard - example environment configuration
#
# ARCHITECTURE NOTE: this app has no direct access to IONOS's RHUI (Red Hat
# Update Infrastructure) servers. Instead, RHEL8_HOST / RHEL9_HOST below are
# RHUI *test clients* -- ordinary VMs already registered to pull updates from
# IONOS RHUI. The app SSHes into each test client and runs the same checks a
# real "dnf update" would run: reading the client's own repo config, resolving
# and reaching the RHUI server, validating certificates, and attempting a live
# metadata fetch and update check. This reproduces exactly what a customer's
# server experiences.
#
# Copy this file to ".env" and fill in the values for your environment.
# If no ".env" is present, the app will present a setup form in the browser
# to collect this same information at runtime (kept in memory unless you
# explicitly choose to save it).
# ==============================================================================

# --- Web server -------------------------------------------------------------
# The app itself listens on this internal port; nginx on web1 reverse-proxies
# the IONOS ALB's external port 8085 (85.215.173.84:8085) to 127.0.0.1:3006.
# See deploy/nginx-rhui-status.conf. Change only if that mapping is updated too.
PORT=3006
SESSION_SECRET=change-me-to-a-random-string

# --- RHEL 8 RHUI test client ---------------------------------------------------
RHEL8_LABEL=RHEL 8 test client
RHEL8_HOST=
RHEL8_SSH_PORT=22
RHEL8_SSH_USER=cloud-user
# Path to a private key file readable by this app (recommended over pasting content)
RHEL8_SSH_KEY_PATH=
# Alternative to RHEL8_SSH_KEY_PATH: paste the full PEM key content here.
# Preserve line breaks as literal "\n" if setting this in a single-line .env value.
RHEL8_SSH_KEY_CONTENT=
RHEL8_SSH_PASSPHRASE=

# --- RHEL 9 RHUI test client ---------------------------------------------------
RHEL9_LABEL=RHEL 9 test client
RHEL9_HOST=
RHEL9_SSH_PORT=22
RHEL9_SSH_USER=cloud-user
RHEL9_SSH_KEY_PATH=
RHEL9_SSH_KEY_CONTENT=
RHEL9_SSH_PASSPHRASE=

# --- RHUI detection -------------------------------------------------------------
# Case-insensitive substring match against each repo's id/baseurl found in the
# client's /etc/yum.repos.d/*.repo files, used to pick out the RHUI repos from
# everything else configured on the box.
RHUI_REPO_FILTER=rhui

# Optional: compare a discovered RHUI repo's live metadata against the public
# Red Hat CDN to see how far behind the public mirrors it is. There's no
# reliable way to derive the public URL from a private RHUI baseurl, so this
# is an explicit opt-in mapping: repoId|publicRepomdUrl, separated by ";".
RHUI_MONITORED_REPOS=rhel-8-for-x86_64-baseos-rhui-rpms|https://cdn.redhat.com/content/dist/rhel8/8/x86_64/baseos/os/repodata/repomd.xml;rhel-9-for-x86_64-baseos-rhui-rpms|https://cdn.redhat.com/content/dist/rhel9/9/x86_64/baseos/os/repodata/repomd.xml

# --- Timeouts (ms) -------------------------------------------------------------
SSH_TIMEOUT_MS=8000
CDN_TIMEOUT_MS=8000

# --- Auto refresh --------------------------------------------------------------
# How often the dashboard polls for fresh status data, in seconds.
STATUS_POLL_INTERVAL_SECONDS=60
